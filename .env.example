# Copy to .env and fill in the values, then run:
#   docker compose --env-file .env up --build

# Required: Blockfrost preprod project id (https://blockfrost.io)
BLOCKFROST_PROJECT_ID_PREPROD=preprod_paste_yours_here

# Required: bech32 address that will receive the 5 tADA payment.
# Use one of YOUR preprod wallet's addresses.
DEMO_PAYTO_ADDRESS=addr_test1qx...replace_me

# Optional. Defaults are sane for local docker compose.
FACILITATOR_URL=http://facilitator:8080
SERVER_PY_PORT=8001
SERVER_TS_PORT=8002
SERVER_JAVA_PORT=8003
SERVER_GO_PORT=8004
FACILITATOR_PORT=8080
FRONTEND_PORT=5173

# CORS origin the resource servers must accept. Match the frontend URL.
CORS_ORIGIN=http://localhost:5173

# Network identifier — the demo is hard-wired to preprod.
X402_NETWORK=cardano:preprod
